# Authentication Configuration
# Generate password hash with: sshler hash-password
SSHLER_USERNAME=your-username
SSHLER_PASSWORD_HASH=your-argon2-hash-here

# Server Configuration (optional)
# SSHLER_HOST=127.0.0.1
# SSHLER_PORT=8822
# SSHLER_PUBLIC_URL=http://localhost:8822
# SSHLER_COOKIE_SECURE=false  # Only for localhost dev! Use true for production

# Security (optional)
# SSHLER_REQUIRE_AUTH=true
# SSHLER_SESSION_TTL=28800  # 8 hours in seconds

# Logging (optional)
# SSHLER_LOG_LEVEL=info
