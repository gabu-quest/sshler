# sshler Environment Configuration
# Copy this file to .env and customize for your deployment

# =============================================================================
# Server Configuration
# =============================================================================
# Host to bind to (use 0.0.0.0 to listen on all interfaces)
# SSHLER_HOST=127.0.0.1

# Port to bind to
# SSHLER_PORT=8822

# Public URL where sshler is accessible (used for origin/CORS validation)
# IMPORTANT: Set this to your actual production URL when behind a reverse proxy
# Examples:
#   - Local dev: http://localhost:8822
#   - LAN: http://192.168.1.100:8822
#   - Tailscale: http://sshler.tail-scale.ts.net
#   - Production: https://sshler.company.internal
# SSHLER_PUBLIC_URL=http://localhost:8822

# =============================================================================
# Authentication (REQUIRED for production)
# =============================================================================
# Generate credentials with: sshler hash-password
# This will automatically add SSHLER_USERNAME and SSHLER_PASSWORD_HASH below

# Username for authentication
# SSHLER_USERNAME=admin

# Option 1: Use pre-hashed password (RECOMMENDED)
# Generate with: sshler hash-password
# SSHLER_PASSWORD_HASH=$argon2id$v=19$m=102400,t=2,p=8$...

# Option 2: Use plain password (NOT recommended - use hash instead)
# SSHLER_PASSWORD=your-strong-password-here

# Require authentication (should always be true in production)
# SSHLER_REQUIRE_AUTH=true

# Auth failed lockout duration in seconds (after 5 failed attempts)
# SSHLER_AUTH_FAILED_LOCKOUT=300

# =============================================================================
# Session/Cookie Settings
# =============================================================================
# Session cookie name
# SSHLER_COOKIE_NAME=sshler_session

# Set Secure flag on cookie (HTTPS only)
# IMPORTANT: Set to true in production when using HTTPS
# Set to false ONLY for localhost HTTP development
# SSHLER_COOKIE_SECURE=true

# SameSite cookie attribute (lax, strict, or none)
# "lax" provides good CSRF protection while allowing normal navigation
# SSHLER_COOKIE_SAMESITE=lax

# Session time-to-live in seconds (default: 8 hours)
# SSHLER_SESSION_TTL_SECONDS=28800

# Session idle timeout in seconds (0 = disabled)
# If set, sessions expire after this many seconds of inactivity
# SSHLER_SESSION_IDLE_TIMEOUT_SECONDS=0

# =============================================================================
# CORS Settings (Advanced)
# =============================================================================
# Comma-separated list of allowed CORS origins
# Leave empty to disable CORS (recommended for same-origin deployments)
# Only enable if you need to access sshler from a different origin
# SSHLER_ALLOWED_ORIGINS=

# Enable Origin header validation on state-changing requests (POST/PUT/PATCH/DELETE)
# Provides CSRF-like protection even with SameSite=Lax
# SSHLER_ORIGIN_CHECK_ENABLED=true

# =============================================================================
# SSH Configuration
# =============================================================================
# Path to custom SSH config file
# SSHLER_SSH_CONFIG=/path/to/custom/ssh_config

# Path to custom sshler config directory
# SSHLER_CONFIG_DIR=/path/to/custom/config

# =============================================================================
# Connection Pool Settings
# =============================================================================
# How long to keep idle SSH connections alive (in seconds)
# Set to "forever" or "none" for unlimited
# Default: 1800 (30 minutes)
# SSHLER_POOL_IDLE_TIMEOUT=1800

# Maximum lifetime for SSH connections (in seconds)
# Set to "forever" or "none" for no expiration
# Default: 3600 (1 hour)
# SSHLER_POOL_MAX_LIFETIME=3600

# Maximum number of pooled connections per box
# Default: 3
# SSHLER_POOL_MAX_CONNECTIONS=3

# =============================================================================
# Upload Settings
# =============================================================================
# Maximum upload size in MB
# SSHLER_MAX_UPLOAD_MB=50

# =============================================================================
# Deployment Mode Examples
# =============================================================================

# --- Localhost Development (HTTP) ---
# SSHLER_HOST=127.0.0.1
# SSHLER_PORT=8822
# SSHLER_PUBLIC_URL=http://localhost:8822
# SSHLER_COOKIE_SECURE=false
# SSHLER_USERNAME=admin
# SSHLER_PASSWORD=DevPassword123!

# --- LAN Deployment with HTTPS (behind Caddy) ---
# SSHLER_HOST=127.0.0.1
# SSHLER_PORT=8822
# SSHLER_PUBLIC_URL=https://sshler.local
# SSHLER_COOKIE_SECURE=true
# SSHLER_USERNAME=admin
# SSHLER_PASSWORD_HASH=$argon2id$v=19$m=102400,t=2,p=8$...

# --- Tailscale Deployment with HTTPS ---
# SSHLER_HOST=100.64.0.1
# SSHLER_PORT=8822
# SSHLER_PUBLIC_URL=https://sshler.tail-scale.ts.net
# SSHLER_COOKIE_SECURE=true
# SSHLER_USERNAME=admin
# SSHLER_PASSWORD_HASH=$argon2id$v=19$m=102400,t=2,p=8$...

# --- Production with Caddy Reverse Proxy ---
# SSHLER_HOST=127.0.0.1
# SSHLER_PORT=8822
# SSHLER_PUBLIC_URL=https://sshler.company.internal
# SSHLER_COOKIE_SECURE=true
# SSHLER_SESSION_TTL_SECONDS=28800
# SSHLER_USERNAME=admin
# SSHLER_PASSWORD_HASH=$argon2id$v=19$m=102400,t=2,p=8$...
