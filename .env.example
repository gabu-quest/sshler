# sshler Environment Configuration
# Copy this file to .env and customize for your deployment

# =============================================================================
# Authentication (REQUIRED for production)
# =============================================================================
# Generate credentials with: sshler hash-password
# This will automatically add SSHLER_USERNAME and SSHLER_PASSWORD_HASH below

# Username for authentication
# SSHLER_USERNAME=admin

# Option 1: Use plain password (NOT recommended - use hash instead)
# SSHLER_PASSWORD=your-strong-password-here

# Option 2: Use pre-hashed password (RECOMMENDED)
# Generate with: sshler hash-password
# SSHLER_PASSWORD_HASH=$argon2id$v=19$m=102400,t=2,p=8$...

# Security settings
# SSHLER_REQUIRE_AUTH=true
# SSHLER_MIN_PASSWORD_LENGTH=12
# SSHLER_AUTH_FAILED_LOCKOUT=300  # seconds to lock out after 5 failed attempts

# =============================================================================
# Server Configuration
# =============================================================================
# SSHLER_HOST=127.0.0.1
# SSHLER_PORT=8822
# SSHLER_MAX_UPLOAD_MB=50

# =============================================================================
# SSH Configuration
# =============================================================================
# Path to custom SSH config file
# SSHLER_SSH_CONFIG=/path/to/custom/ssh_config

# Path to custom sshler config directory
# SSHLER_CONFIG_DIR=/path/to/custom/config

# =============================================================================
# Connection Pool Settings
# =============================================================================
# How long to keep idle SSH connections alive (in seconds)
# Set to "forever" or "none" for unlimited
# Default: 1800 (30 minutes)
SSHLER_POOL_IDLE_TIMEOUT=1800

# Maximum lifetime for SSH connections (in seconds)
# Set to "forever" or "none" for no expiration
# Default: 3600 (1 hour)
SSHLER_POOL_MAX_LIFETIME=3600

# Maximum number of pooled connections per box
# Default: 3
SSHLER_POOL_MAX_CONNECTIONS=3
